// DBU-POC Prisma schema — shared Aiven MySQL
// Every model uses @@map("dbu_<name>") to stay strictly within the dbu_ prefix.
// Aiven supports native FKs, so relationMode defaults to "foreignKeys".

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  CLIENT
  BARBER
  ADMIN
}

enum Rank {
  MEMBER
  PRO
  ELITE
  COACH
  DYNASTY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum CommissionStatus {
  PENDING
  APPROVED
  CANCELED
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  REFUNDED
}

enum ProductType {
  BOOKING
  MEMBERSHIP
  COACHING
}

// ─── Users / Network ────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  name                  String
  phone                 String?
  role                  Role      @default(CLIENT)
  rank                  Rank?     // only set when role = BARBER
  referralCode          String    @unique
  sponsorId             String?
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  isSubscriptionWaived  Boolean   @default(false)
  hasFirstPayment       Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  sponsor               User?     @relation("Sponsorship", fields: [sponsorId], references: [id], onDelete: SetNull)
  sponsees              User[]    @relation("Sponsorship")

  barberProfile         BarberProfile?
  clientBookings        Booking[]       @relation("ClientBookings")
  barberBookings        Booking[]       @relation("BarberBookings")
  commissionsReceived   Commission[]    @relation("CommissionBeneficiary")
  commissionsPaid       Commission[]    @relation("CommissionPayer")
  payments              Payment[]
  courseProgress        CourseProgress[]
  adminActionsPerformed AdminActionLog[]

  @@index([sponsorId])
  @@index([role])
  @@map("dbu_users")
}

// ─── Barber / Services / Bookings ───────────────────────────────────────────

model BarberProfile {
  userId             String   @id
  slug               String   @unique
  bio                String?  @db.Text
  weeklyAvailability Json     // { "mon": [["09:00","17:00"]], "tue": [...], ... }
  capacityTargetHrs  Int      @default(40) // weekly target hours for 90% calc
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  services Service[]

  @@map("dbu_barber_profiles")
}

model Service {
  id              String   @id @default(cuid())
  barberProfileId String
  name            String
  durationMin     Int
  priceCents      Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barberProfile BarberProfile @relation(fields: [barberProfileId], references: [userId], onDelete: Cascade)
  bookings      Booking[]

  @@index([barberProfileId])
  @@map("dbu_services")
}

model Booking {
  id                     String        @id @default(cuid())
  barberId               String
  clientId               String
  serviceId              String
  startAt                DateTime
  endAt                  DateTime
  status                 BookingStatus @default(PENDING)
  stripePaymentIntentId  String?       @unique
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  barber  User    @relation("BarberBookings", fields: [barberId], references: [id], onDelete: Cascade)
  client  User    @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@index([barberId, startAt])
  @@index([clientId, startAt])
  @@index([status])
  @@map("dbu_bookings")
}

// ─── Payments / Commissions ─────────────────────────────────────────────────

model Payment {
  id                     String        @id @default(cuid())
  stripePaymentIntentId  String        @unique
  userId                 String
  amountCents            Int
  productType            ProductType
  status                 PaymentStatus @default(SUCCEEDED)
  createdAt              DateTime      @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions Commission[]

  @@index([userId])
  @@map("dbu_payments")
}

model Commission {
  id              String           @id @default(cuid())
  sourcePaymentId String           // Payment.id (easier to join) — unique per (payment, beneficiary, level)
  beneficiaryId   String
  payerId         String
  level           Int              // 1..7
  rankAtPayout    Rank
  amountCents    Int
  status          CommissionStatus @default(PENDING)
  releaseAt       DateTime
  createdAt       DateTime         @default(now())

  payment     Payment @relation(fields: [sourcePaymentId], references: [id], onDelete: Cascade)
  beneficiary User    @relation("CommissionBeneficiary", fields: [beneficiaryId], references: [id], onDelete: Cascade)
  payer       User    @relation("CommissionPayer", fields: [payerId], references: [id], onDelete: Cascade)

  @@unique([sourcePaymentId, beneficiaryId, level])
  @@index([beneficiaryId, status])
  @@index([status, releaseAt])
  @@map("dbu_commissions")
}

// ─── Courses ────────────────────────────────────────────────────────────────

model CourseModule {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  loomUrl     String
  orderIndex  Int
  unlockRule  Json     // { "type": "capacity_gte", "value": 0.9 } or { "type": "rank_gte", "value": "PRO" } or { "type": "always" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  progress CourseProgress[]

  @@index([orderIndex])
  @@map("dbu_course_modules")
}

model CourseProgress {
  userId      String
  moduleId    String
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([userId, moduleId])
  @@map("dbu_course_progress")
}

// ─── Admin / Audit ──────────────────────────────────────────────────────────

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String   // e.g. "user.rank.update", "commission.release"
  targetType String   // e.g. "user", "commission"
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
  @@map("dbu_admin_action_logs")
}

// ─── Idempotency ────────────────────────────────────────────────────────────

model WebhookEvent {
  id              String   @id @default(cuid())
  stripeEventId   String   @unique
  type            String
  payload         Json
  processedAt     DateTime @default(now())

  @@index([type, processedAt])
  @@map("dbu_webhook_events")
}
