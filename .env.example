# ─── Database (Aiven MySQL, shared) ────────────────────────────────────────
# Aiven provides a CA certificate — download from Aiven console, save to ./cert/ca.pem
# (the `cert/` folder is gitignored; only `ca.pem` itself is excluded, not the folder).
#
# Prisma-native MySQL SSL params:
#   sslaccept=strict       → verify server cert against CA
#   sslcert=./cert/ca.pem  → path to Aiven CA (forward slashes, relative to cwd)
#
# Local dev format:
DATABASE_URL="mysql://USER:PASSWORD@HOST.aivencloud.com:PORT/DBNAME?sslaccept=strict&sslcert=./cert/ca.pem"
#
# Vercel production: the cert file won't be in the deployment bundle by default.
# For POC we'll switch the prod URL to `?sslaccept=strict` without sslcert — Aiven
# still enforces TLS, just without client-side CA verification. Addressed at deploy time.

# ─── Auth.js (NextAuth v5) ─────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Local dev URL (leave unset in production — Vercel sets it automatically)
NEXTAUTH_URL="http://localhost:3000"

# ─── Stripe (sandbox / test mode) ──────────────────────────────────────────
# From https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — required for the webhook route to verify Stripe signatures.
# Local dev: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe` and copy the whsec_... it prints.
# Production: create a webhook endpoint in the Stripe dashboard, copy its signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Test Price ID for the "DBU Membership" subscription. OPTIONAL —
# if not set, the app will look up (or create) a $29/month membership price in Stripe automatically on first use.
STRIPE_MEMBERSHIP_PRICE_ID="price_..."

# ─── Commission Engine ─────────────────────────────────────────────────────
# Days to hold commissions as PENDING before they can be released to APPROVED.
# Set to 0 in development to demo the release flow without waiting.
COMMISSION_HOLD_DAYS="14"

# ─── App ───────────────────────────────────────────────────────────────────
# Base URL used in server-side code (e.g., building referral links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
